# Ambiente virtual (cada um cria o seu — não vai pro repositório)
.venv/

# Arquivos temporários que o Python gera
__pycache__/
*.pyc

# Diário de bordo local (só interessa nesta máquina)
yato.log
yato.log.*
avatar.log
avatar.log.*

# Suas conversas e os fatos sobre você são DADO PESSOAL, não código
conversa.json
conversas/
fatos.json

# Modelos de voz do Piper (~60 MB cada) — baixáveis, como o modelo do Ollama.
# Quem clonar baixa a voz (instruções no README).
vozes/

# As imagens que o Yato desenha são SEU conteúdo gerado, não código do projeto.
imagens_geradas/

# O Electron do avatar (~200 MB) é baixado pelo npm install (o preparar.py roda).
# Só o código (main.js/preload.js/package.json) vai pro repo.
avatar-electron/node_modules/

# O atalho "Yato.lnk" tem caminhos ABSOLUTOS desta máquina — o preparar.py
# recria ele em cada máquina, então não vai pro repositório.
*.lnk
